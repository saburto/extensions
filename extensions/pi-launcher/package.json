{
  "name": "@pi-extensions/pi-launcher",
  "version": "0.0.1",
  "private": true,
  "keywords": ["pi-package"],
  "files": ["src"],
  "type": "module",
  "exports": {
    ".": "./src/extension.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
