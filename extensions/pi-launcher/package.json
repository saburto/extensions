{
  "name": "@saburto/pi-launcher",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/extension.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
